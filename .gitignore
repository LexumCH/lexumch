# ═══════════════════════════════════════════════════════════════
# LEXUM CH — .gitignore frontend
# ═══════════════════════════════════════════════════════════════
# Da posizionare in ~/LEXUM CH/.gitignore

# ─── SECRET (mai committare!) ───
.env
.env.local
.env.*.local
!.env.example
*.key
*.pem

# ─── Build output ───
dist/
build/
.vercel/
.next/
out/

# ─── Dependencies ───
node_modules/
.pnp/
.pnp.js
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml

# ─── Logs ───
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── Cache Vite / framework ───
.vite/
.cache/
.parcel-cache/

# ─── Test / coverage ───
coverage/
.nyc_output/

# ─── Editor ───
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── OS ───
Thumbs.db
desktop.ini
